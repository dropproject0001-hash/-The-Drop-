{
  "name": "droppin-ops",
  "private": true,
  "version": "0.1.0",
  "description": "DROPPIN OPS — Secure real-time GPS-based product drop tracking system (Supabase + React + Leaflet PWA)",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "lint:env": "grep -rni --include='*.ts' --include='*.tsx' 'firebase\\|FIREBASE\\|Firebase' src/ 2>/dev/null | grep -v node_modules && exit 1 || echo '✅ No Firebase references found in src/'",
    "prebuild": "npm run lint:env",
    "validate:env": "node --loader tsx --no-warnings ./src/lib/validateEnv.ts",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.107.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.101.0",
    "@vitejs/plugin-react": "^5.0.4",
    "browser-image-compression": "^2.0.2",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.40.0",
    "html5-qrcode": "^2.3.8",
    "immer": "^11.1.8",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "adm-zip": "^0.5.17",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run lint:env"
    ]
  }
}
