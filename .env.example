# ──────────────────────────────────────────────────────────────────
# DropPin Ops — Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to source control.
# ──────────────────────────────────────────────────────────────────

# Gemini AI (injected automatically by AI Studio at runtime)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App URL (injected automatically by AI Studio with the Cloud Run URL)
APP_URL="MY_APP_URL"

# ── Supabase ────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY" # Secure Service Role Key for local edge function gateway

# ── Push Notifications ──────────────────────────────────────────────
VITE_VAPID_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY"

# ── Map Tiles (optional — Stadia Maps fallback) ─────────────────────
VITE_STADIA_API_KEY="YOUR_STADIA_API_KEY"

# ── Twilio SMS Gateway (for sandboxed send-otp backup) ────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── Tactical Rule Settings ───────────────────────────────────────
STRICT_GOODS_EYE="false" # Require active drop ID and validity in location broadcasts
RATE_LIMIT_MS="4000"     # Antispam interval between consecutive location pings
VITE_CRYPTO_SECRET=""    # Key for encrypting chat notes
