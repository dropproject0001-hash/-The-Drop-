# ──────────────────────────────────────────────────────────────────
# DropPin Ops — Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to source control.
# ──────────────────────────────────────────────────────────────────

# Gemini AI (injected automatically by AI Studio at runtime)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App URL (injected automatically by AI Studio with the Cloud Run URL)
APP_URL="MY_APP_URL"

# ── Supabase ────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# ── Push Notifications ──────────────────────────────────────────────
VITE_VAPID_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY"

# ── Map Tiles (optional — Stadia Maps fallback) ─────────────────────
VITE_STADIA_API_KEY="YOUR_STADIA_API_KEY"

# ── Firebase (FIX C-2: moved from hardcoded firebase-applet-config.json) ──
# Add firebase-applet-config.json to .gitignore after migrating.
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID"
VITE_FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
# Optional: custom Firestore database ID (leave blank for '(default)')
VITE_FIREBASE_FIRESTORE_DB=""
